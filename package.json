{
  "name": "basis",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered research desktop app (Basis)",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"bun run dev:renderer\" \"bun run dev:electron\"",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && bun run build:electron && electron .",
    "build": "vite build && bun run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "preview": "vite preview",
    "postinstall": "electron-builder install-app-deps",
    "dist": "bun run build && electron-builder"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.0",
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/plus-jakarta-sans": "^5.2.8",
    "@legendapp/list": "3.0.0-beta.44",
    "@milkdown/crepe": "^7.17.1",
    "@milkdown/kit": "^7.17.1",
    "@pierre/trees": "^1.0.0-beta.3",
    "@tanstack/react-query": "^5.90.5",
    "better-sqlite3": "^12.4.1",
    "buffer": "6.0.3",
    "chokidar": "^4.0.3",
    "electron-store": "^11.0.2",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.8.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-icons": "^5.6.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.10.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.7.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.0.4",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "postcss": "^8.5.9",
    "tailwindcss": "3",
    "typescript": "^5.9.3",
    "vite": "^7.1.10",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.clepro.basis",
    "productName": "Basis",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
